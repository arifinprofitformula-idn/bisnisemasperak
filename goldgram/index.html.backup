<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Goldgram - Investasi Emas Modern</title>
  
  <!-- Preload Critical Resources -->
  <link rel="preload" href="https://bisnisemasperak.com/goldgram/logogg.png" as="image" type="image/png">
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"></noscript>
  
  <!-- DNS Prefetch for External Resources -->
  <link rel="dns-prefetch" href="//cdn.jsdelivr.net">
  <link rel="dns-prefetch" href="//fonts.googleapis.com">
  
  <!-- Critical CSS Inlined -->
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
      color: #ffffff;
      line-height: 1.7;
      overflow-x: hidden;
    }
    
    /* Layout Shift Prevention */
    img {
      max-width: 100%;
      height: auto;
      display: block;
    }
    
    .logo img {
      aspect-ratio: 200 / 60;
      width: 200px;
      height: 60px;
    }
    
    .product-card img {
      aspect-ratio: 200 / 150;
      width: 200px;
      height: 150px;
      object-fit: cover;
    }
    
    /* Performance optimizations */
    .floating-whatsapp {
      will-change: transform, opacity;
    }
    
    .product-card {
      will-change: transform, opacity;
    }
    
    .container {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 20px;
    }
    
    /* Header Styles */
    header {
      text-align: center;
      padding: 60px 0 40px;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    
    header::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 80px;
      height: 2px;
      background: linear-gradient(90deg, #d4af37, #f4d03f);
    }
    
    header img {
      max-height: 90px;
      filter: drop-shadow(0 4px 12px rgba(212, 175, 55, 0.3));
      transform: scale(0.5);
      max-width: 100%;
      height: auto;
    }
    
    /* Typography */
    h1, h2, h3 {
      color: #d4af37;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    
    h1 {
      font-size: clamp(2.5rem, 4vw, 3.5rem);
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    h2 {
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      margin-bottom: 2rem;
      text-align: center;
    }
    
    h3 {
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }
    
    p {
      color: #e0e0e0;
      font-size: 1.1rem;
      line-height: 1.8;
    }
    
    /* Hero Section */
    .hero {
      text-align: center;
      padding: 100px 40px;
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      border-radius: 20px;
      margin: 40px 0;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }
    
    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 50% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
      pointer-events: none;
    }
    
    .hero-content {
      position: relative;
      z-index: 2;
    }
    
    .hero p {
      font-size: 1.3rem;
      margin-bottom: 2.5rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    
    /* CTA Button */
    .cta-btn {
      display: inline-block;
      padding: 18px 40px;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      color: #000;
      text-decoration: none;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.1rem;
      margin-top: 20px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 8px 25px rgba(212, 175, 55, 0.3);
      position: relative;
      overflow: hidden;
    }
    
    .cta-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s;
    }
    
    .cta-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 35px rgba(212, 175, 55, 0.4);
    }
    
    .cta-btn:hover::before {
      left: 100%;
    }
    
    /* Section Styles */
    .section {
      margin: 80px 0;
      position: relative;
    }
    
    /* Grid Layouts */
    .features, .benefits, .faq, .testimoni {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 30px;
      margin-top: 50px;
    }
    
    /* Feature Icon Styles */
    .feature-icon {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(244, 208, 63, 0.1));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      transition: all 0.3s ease;
    }
    
    .feature-icon svg {
      color: #d4af37;
      transition: all 0.3s ease;
    }
    
    .card:hover .feature-icon {
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.2), rgba(244, 208, 63, 0.2));
      transform: scale(1.1);
    }
    
    .card:hover .feature-icon svg {
      color: #f4d03f;
    }
    
    .card {
      background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 100%);
      padding: 35px;
      border-radius: 16px;
      border: 1px solid rgba(212, 175, 55, 0.1);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }
    
    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #d4af37, #f4d03f);
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }
    
    .card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      border-color: rgba(212, 175, 55, 0.3);
    }
    
    .card:hover::before {
      transform: scaleX(1);
    }
    
    /* Product Images */
    img.product {
      max-width: 100%;
      border-radius: 12px;
      margin-bottom: 20px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s ease;
    }
    
    img.product:hover {
      transform: scale(1.05);
    }
    
    /* Testimonial Styles */
    .testimoni .card {
      text-align: center;
      position: relative;
    }
    
    .testimoni .card::before {
      content: '"';
      position: absolute;
      top: 15px;
      left: 25px;
      font-size: 4rem;
      color: rgba(212, 175, 55, 0.3);
      font-family: serif;
    }
    
    .testimoni p {
      font-style: italic;
      margin-bottom: 20px;
      font-size: 1.1rem;
    }
    
    .testimoni small {
      color: #d4af37;
      font-weight: 600;
    }

    /* Product Catalog Styles */
    .product-catalog {
      background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 100%);
      padding: 80px 0;
      border-radius: 20px;
      margin: 80px 0;
      position: relative;
      overflow: hidden;
    }

    .product-catalog::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(244, 208, 63, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      margin: 50px 0;
      position: relative;
      z-index: 1;
    }

    .product-card {
      background: transparent;
      border-radius: 20px;
      padding: 25px;
      border: none;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .product-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: transparent;
      transform: scaleX(0);
      transition: transform 0.4s ease;
    }

    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .product-card:hover::before {
      transform: scaleX(1);
    }

    .product-image {
      position: relative;
      margin-bottom: 25px;
      border-radius: 16px;
      overflow: hidden;
      background: transparent;
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 200px;
    }

    .product-image img {
      max-width: 100%;
      max-height: 160px;
      width: auto;
      height: auto;
      object-fit: contain;
      transition: all 0.4s ease;
      filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
    }

    .product-card:hover .product-image img {
      transform: scale(1.1);
      filter: drop-shadow(0 15px 30px rgba(212, 175, 55, 0.2));
    }

    .product-info h3 {
      color: #f4d03f;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 15px;
      text-align: center;
    }

    .product-specs {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding: 12px 20px;
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(244, 208, 63, 0.1));
      border-radius: 12px;
      border: 1px solid rgba(212, 175, 55, 0.2);
    }

    .product-specs .weight {
      color: #ffffff;
      font-weight: 600;
      font-size: 1.1rem;
    }

    .product-specs .purity {
      color: #d4af37;
      font-weight: 700;
      font-size: 1.1rem;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .product-features {
      margin-bottom: 20px;
    }

    .product-features .feature {
      display: block;
      color: #b8b8b8;
      font-size: 0.9rem;
      margin-bottom: 8px;
      padding-left: 5px;
    }

    .product-features .feature::before {
      content: '✓';
      color: #d4af37;
      font-weight: bold;
      margin-right: 8px;
    }

    .product-price {
      text-align: center;
      padding: 20px 0;
      border-top: 1px solid rgba(212, 175, 55, 0.2);
    }

    .product-price .price-label {
      display: block;
      color: #888;
      font-size: 0.9rem;
      margin-bottom: 8px;
    }

    .product-price .price {
      color: #f4d03f;
      font-size: 1.3rem;
      font-weight: 700;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .catalog-footer {
      text-align: center;
      margin-top: 60px;
      padding: 40px 20px;
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.05), rgba(244, 208, 63, 0.05));
      border-radius: 16px;
      border: 1px solid rgba(212, 175, 55, 0.1);
      position: relative;
      z-index: 1;
    }

    .catalog-footer p {
      color: #b8b8b8;
      margin-bottom: 30px;
      font-size: 1rem;
    }

    .contact-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary, .btn-secondary {
      padding: 15px 30px;
      border-radius: 12px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s ease;
      border: 2px solid transparent;
      display: inline-block;
    }

    .btn-primary {
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      color: #000;
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #f4d03f, #d4af37);
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
    }

    .btn-secondary {
      background: transparent;
      color: #d4af37;
      border-color: #d4af37;
    }

    .btn-secondary:hover {
      background: rgba(212, 175, 55, 0.1);
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
    }

    /* Responsive Design for Product Catalog */
    @media (max-width: 1200px) {
      .product-grid {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
      }
    }

    @media (max-width: 768px) {
      .product-catalog {
        padding: 60px 0;
        margin: 60px 0;
      }

      .product-grid {
        grid-template-columns: 1fr;
        gap: 20px;
        margin: 40px 0;
      }

      .product-card {
        padding: 20px;
      }

      .product-image {
        min-height: 180px;
        padding: 15px;
      }

      .product-image img {
        max-height: 140px;
      }

      .contact-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn-primary, .btn-secondary {
        width: 100%;
        max-width: 280px;
      }
    }

    @media (max-width: 480px) {
      .product-specs {
        flex-direction: column;
        gap: 10px;
        text-align: center;
      }

      .product-info h3 {
        font-size: 1.3rem;
      }

      .product-price .price {
        font-size: 1.2rem;
      }
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 60px 0;
      border-top: 1px solid rgba(212, 175, 55, 0.2);
      margin-top: 80px;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
    }
    
    footer p {
      color: #888;
      font-size: 0.95rem;
    }
    
    /* Responsive Design */
    @media (max-width: 768px) {
      .container {
        padding: 0 15px;
      }
      
      .hero {
        padding: 60px 20px;
        margin: 20px 0;
      }
      
      .features, .benefits, .faq, .testimoni {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      
      .card {
        padding: 25px;
      }
      
      .section {
        margin: 50px 0;
      }
      
      h2 {
        margin-bottom: 1.5rem;
      }
    }
    
    @media (max-width: 480px) {
      .hero {
        padding: 40px 15px;
      }
      
      .cta-btn {
        padding: 15px 30px;
        font-size: 1rem;
      }
      
      .card {
        padding: 20px;
      }
    }
    
    /* Monitor Frame Video Embed Styles */
    .monitor-container {
      position: relative;
      width: 100%;
      max-width: 600px;
      margin: 3rem auto;
      perspective: 1000px;
    }
    
    .monitor-frame {
      position: relative;
      background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
      border-radius: 8px;
      padding: 25px 25px 15px 25px;
      box-shadow: 
        0 20px 40px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
      transform: rotateX(5deg) rotateY(-2deg);
      transition: transform 0.3s ease;
    }
    
    .monitor-frame:hover {
      transform: rotateX(0deg) rotateY(0deg);
    }
    
    .monitor-screen {
      position: relative;
      width: 100%;
      padding-bottom: 56.25%; /* 16:9 aspect ratio */
      background: #000;
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 
        inset 0 0 20px rgba(0, 0, 0, 0.8),
        0 0 0 2px #333;
    }
    
    .monitor-screen iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    
    /* Monitor Stand */
    .monitor-stand {
      position: relative;
      width: 120px;
      height: 40px;
      background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
      margin: 0 auto;
      border-radius: 0 0 8px 8px;
      box-shadow: 
        0 5px 15px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }
    
    .monitor-base {
      position: relative;
      width: 200px;
      height: 15px;
      background: linear-gradient(145deg, #2a2a2a, #1a1a1a);
      margin: 0 auto;
      border-radius: 20px;
      box-shadow: 0 3px 10px rgba(0, 0, 0, 0.3);
    }
    
    /* Monitor Controls */
    .monitor-controls {
      position: absolute;
      bottom: 8px;
      right: 15px;
      display: flex;
      gap: 8px;
      align-items: center;
    }
    
    .power-button {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: linear-gradient(145deg, #4a4a4a, #2a2a2a);
      border: 1px solid #555;
      position: relative;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .power-button:hover {
      background: linear-gradient(145deg, #0066ff, #0044cc);
      box-shadow: 0 0 8px rgba(0, 102, 255, 0.5);
    }
    
    .power-button::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 6px;
      height: 6px;
      border: 1px solid #888;
      border-radius: 50%;
      border-top: 1px solid transparent;
    }
    
    .control-buttons {
      display: flex;
      gap: 4px;
    }
    
    .control-btn {
      width: 8px;
      height: 8px;
      background: linear-gradient(145deg, #4a4a4a, #2a2a2a);
      border: 1px solid #555;
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.2s ease;
    }
    
    .control-btn:hover {
      background: linear-gradient(145deg, #5a5a5a, #3a3a3a);
    }
    
    /* Monitor Ports */
    .monitor-ports {
      position: absolute;
      bottom: 8px;
      left: 15px;
      display: flex;
      gap: 6px;
      align-items: center;
    }
    
    .port {
      width: 12px;
      height: 6px;
      background: #000;
      border: 1px solid #333;
      border-radius: 1px;
      position: relative;
    }
    
    .port.hdmi {
      width: 14px;
      height: 5px;
    }
    
    .port.usb {
      width: 8px;
      height: 4px;
      border-radius: 2px;
    }
    
    .port::after {
      content: attr(data-label);
      position: absolute;
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 6px;
      color: #666;
      white-space: nowrap;
    }
    
    /* Monitor Brand Label */
    .monitor-brand {
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 8px;
      color: #666;
      font-weight: 300;
      letter-spacing: 1px;
    }
    
    /* Responsive Design */
    @media (max-width: 768px) {
      .monitor-container {
        max-width: 90%;
        margin: 2rem auto;
      }
      
      .monitor-frame {
        padding: 20px 20px 12px 20px;
        transform: none;
      }
      
      .monitor-frame:hover {
        transform: none;
      }
      
      .monitor-stand {
        width: 100px;
        height: 35px;
      }
      
      .monitor-base {
        width: 160px;
        height: 12px;
      }
    }
    
    /* Floating WhatsApp Button */
    .floating-whatsapp {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #25d366, #128c7e);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
      z-index: 1000;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      animation: pulse 2s infinite;
    }
    
    .floating-whatsapp:hover {
      transform: scale(1.1);
      box-shadow: 0 12px 35px rgba(37, 211, 102, 0.6);
    }
    
    .floating-whatsapp svg {
      width: 32px;
      height: 32px;
      fill: white;
    }
    
    @keyframes pulse {
      0% {
        box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
      }
      50% {
        box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4), 0 0 0 10px rgba(37, 211, 102, 0.1);
      }
      100% {
        box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
      }
    }
    
    /* FAQ Toggle Styles */
    .faq-item {
      border: 1px solid rgba(212, 175, 55, 0.1);
      border-radius: 12px;
      margin-bottom: 15px;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    
    .faq-question {
      background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 100%);
      padding: 25px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.3s ease;
      border: none;
      width: 100%;
      text-align: left;
    }
    
    .faq-question:hover {
      background: linear-gradient(135deg, #2a2a2a 0%, #333 100%);
    }
    
    .faq-question h3 {
      margin: 0;
      color: #d4af37;
      font-size: 1.2rem;
    }
    
    .faq-toggle {
      font-size: 1.5rem;
      color: #d4af37;
      transition: transform 0.3s ease;
    }
    
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      background: #1a1a1a;
    }
    
    .faq-answer.active {
      max-height: 200px;
    }
    
    .faq-answer p {
      padding: 25px;
      margin: 0;
    }
    
    .faq-item.active .faq-toggle {
      transform: rotate(45deg);
    }
    
    /* Product Catalog Styles */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 25px;
      margin-top: 50px;
    }
    
    .product-card {
      background: transparent;
      border-radius: 16px;
      padding: 30px;
      text-align: center;
      border: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    
    .product-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: transparent;
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }
    
    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }
    
    .product-card:hover::before {
      transform: scaleX(1);
    }
    
    .product-image {
      margin-bottom: 20px;
      border-radius: 10px;
      overflow: hidden;
      background: transparent;
      padding: 10px;
    }
    
    .product-image img {
      width: 100%;
      height: 120px;
      object-fit: cover;
      border-radius: 8px;
      transition: transform 0.3s ease;
    }
    
    .product-card:hover .product-image img {
      transform: scale(1.05);
    }
    
    .product-weight {
      font-size: 2.5rem;
      font-weight: 700;
      color: #d4af37;
      margin-bottom: 10px;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .product-title {
      font-size: 1.3rem;
      margin-bottom: 15px;
      color: #fff;
    }
    .product-segment {
      font-size: 0.95rem;
      color: #cfcfcf;
      line-height: 1.5;
      margin-bottom: 15px;
    }
    
    .product-price {
      font-size: 1.1rem;
      color: #e0e0e0;
      margin-bottom: 20px;
    }
    
    .product-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 25px;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      color: #000;
      text-decoration: none;
      border-radius: 25px;
      font-weight: 600;
      transition: all 0.3s ease;
      font-size: 0.95rem;
      margin-top: auto;
    }
    
    .product-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4);
    }
    
    .product-btn svg {
      flex-shrink: 0;
    }
    
    /* Smooth Scrolling */
    html {
      scroll-behavior: smooth;
    }
    
    /* Loading Animation */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .section {
      animation: fadeInUp 0.6s ease-out;
    }
    
    /* Gold Investment Section - Modern Dark Theme */
    .gold-investment-section {
      margin-top: 50px;
    }
    
    .main-chart-card {
      background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 100%);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
      position: relative;
      overflow: hidden;
    }
    
    .main-chart-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #d4af37, #f4d03f, #d4af37);
    }
    
    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 16px;
    }
    
    .chart-header h3 {
      color: #d4af37;
      font-size: 1.8rem;
      font-weight: 700;
      margin: 0;
    }
    
    .data-source {
      font-size: 0.9rem;
      color: #999;
    }
    
    .data-source a {
      color: #d4af37;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.3s ease;
    }
    
    .data-source a:hover {
      color: #f4d03f;
    }
    
    .chart-wrapper {
      position: relative;
      width: 100%;
      min-height: 450px;
      margin: 30px 0;
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.4), rgba(212, 175, 55, 0.1));
      border-radius: 16px;
      padding: 25px;
      border: 2px solid rgba(212, 175, 55, 0.2);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 
                  0 0 20px rgba(212, 175, 55, 0.1);
      backdrop-filter: blur(10px);
      transition: all 0.3s ease;
      overflow: hidden;
    }
    
    .chart-wrapper:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 
                  0 0 30px rgba(212, 175, 55, 0.2);
      border-color: rgba(212, 175, 55, 0.3);
    }
    
    .chart-wrapper::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #d4af37, #f4d03f, #d4af37);
      border-radius: 16px 16px 0 0;
    }
    
    /* Responsive styling untuk embed widget */
    .chart-wrapper a[id^="brtChart"] {
      display: block;
      width: 100% !important;
      min-height: 400px;
      border-radius: 12px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    /* Styling untuk iframe yang di-generate oleh script */
    .chart-wrapper iframe {
      width: 100% !important;
      height: 400px !important;
      border: none !important;
      border-radius: 12px !important;
      background: #fff;
    }
    
    .integrated-analysis {
      margin: 40px 0;
      padding: 30px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 16px;
      border: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    .analysis-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-bottom: 20px;
    }
    
    .analysis-row:last-child {
      margin-bottom: 0;
    }
    
    .analysis-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px;
      background: rgba(212, 175, 55, 0.05);
      border-radius: 12px;
      border: 1px solid rgba(212, 175, 55, 0.1);
      transition: all 0.3s ease;
    }
    
    .analysis-item:hover {
      background: rgba(212, 175, 55, 0.1);
      border-color: rgba(212, 175, 55, 0.3);
      transform: translateY(-2px);
    }
    
    .analysis-icon {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, #d4af37, #f4d03f);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1a1a1a;
      flex-shrink: 0;
    }
    
    .analysis-content h4 {
      color: #d4af37;
      font-size: 1.1rem;
      font-weight: 600;
      margin: 0 0 8px 0;
    }
    
    .analysis-content p {
      color: #e0e0e0;
      font-size: 0.9rem;
      line-height: 1.5;
      margin: 0;
    }
    
    .integrated-comparison {
      padding: 30px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 16px;
      border: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    .comparison-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
    }
    
    .comparison-header h4 {
      color: #d4af37;
      font-size: 1.4rem;
      font-weight: 600;
      margin: 0;
    }
    
    .comparison-source {
      font-size: 0.85rem;
      color: #999;
    }
    
    .comparison-source a {
      color: #d4af37;
      text-decoration: none;
      font-weight: 500;
    }
    
    .comparison-grid {
      display: grid;
      gap: 16px;
    }
    
    .comparison-item {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 16px;
      background: rgba(212, 175, 55, 0.05);
      border-radius: 12px;
      border: 1px solid rgba(212, 175, 55, 0.1);
      transition: all 0.3s ease;
    }
    
    .comparison-item:hover {
      background: rgba(212, 175, 55, 0.1);
      transform: translateX(4px);
    }
    
    .investment-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      min-width: 140px;
      flex-shrink: 0;
    }
    
    .investment-type {
      font-weight: 500;
      color: #e0e0e0;
      font-size: 0.95rem;
    }
    
    .investment-return {
      font-weight: 700;
      font-size: 1rem;
      color: #d4af37;
    }
    
    .return-bar {
      flex: 1;
      height: 8px;
      border-radius: 4px;
      position: relative;
      overflow: hidden;
    }
    
    .gold-bar {
      background: linear-gradient(90deg, #d4af37, #f4d03f);
      width: 100%;
    }
    
    .property-bar {
      background: linear-gradient(90deg, #e74c3c, #ec7063);
      width: 75%;
    }
    
    .stock-bar {
      background: linear-gradient(90deg, #3498db, #5dade2);
      width: 70%;
    }
    
    .deposit-bar {
      background: linear-gradient(90deg, #95a5a6, #bdc3c7);
      width: 53%;
    }
    
    /* Responsive Design for Gold Investment Section */
    @media (max-width: 1024px) {
      .main-chart-card {
        padding: 30px;
      }
      
      .chart-header {
        flex-direction: column;
        align-items: flex-start;
      }
      
      .chart-wrapper {
        height: 350px;
      }
      
      .analysis-row {
        grid-template-columns: 1fr;
      }
    }
    
    @media (max-width: 768px) {
      .main-chart-card {
        padding: 20px;
        border-radius: 16px;
      }
      
      .chart-header h3 {
        font-size: 1.4rem;
      }
      
      .chart-wrapper {
        height: 300px;
        padding: 16px;
      }
      
      .integrated-analysis,
      .integrated-comparison {
        padding: 20px;
      }
      
      .analysis-item {
        flex-direction: column;
        text-align: center;
        gap: 12px;
      }
      
      .comparison-header {
        flex-direction: column;
        align-items: flex-start;
      }
      
      .comparison-item {
        flex-direction: column;
        gap: 12px;
      }
      
      .investment-info {
        width: 100%;
        min-width: auto;
      }
      
      .return-bar {
        width: 100%;
        height: 6px;
      }
    }

    /* Trend Education Section */
    .trend-education-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-bottom: 4rem;
    }

    .trend-card {
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 16px;
      padding: 24px;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .trend-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #d4af37, #f4d03f);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .trend-card:hover {
      transform: translateY(-8px);
      border-color: rgba(212, 175, 55, 0.4);
      box-shadow: 0 12px 32px rgba(212, 175, 55, 0.15);
    }

    .trend-card:hover::before {
      opacity: 1;
    }

    .trend-card.highlight {
      border-color: rgba(212, 175, 55, 0.4);
      background: linear-gradient(135deg, #2d2d2d 0%, #3d3d3d 100%);
    }

    .trend-card.mega-highlight {
      border-color: #d4af37;
      background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%);
      color: #1a1a1a;
      transform: scale(1.05);
    }

    .trend-card.mega-highlight .trend-value,
    .trend-card.mega-highlight .trend-amount {
      color: #1a1a1a;
    }

    .trend-period {
      font-size: 0.9rem;
      color: #a0a0a0;
      margin-bottom: 8px;
      font-weight: 500;
    }

    .trend-value {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .trend-value.positive {
      color: #4ade80;
    }

    .trend-value.mega {
      font-size: 2.5rem;
      background: linear-gradient(45deg, #1a1a1a, #2d2d2d);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .trend-amount {
      font-size: 1.1rem;
      color: #d4af37;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .trend-amount.mega {
      font-size: 1.3rem;
      color: #1a1a1a;
    }

    .trend-description {
      font-size: 0.9rem;
      color: #b0b0b0;
      line-height: 1.4;
    }

    .trend-insights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-bottom: 3rem;
    }

    .insight-card {
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
      transition: all 0.3s ease;
    }

    .insight-card:hover {
      transform: translateY(-4px);
      border-color: rgba(212, 175, 55, 0.4);
      box-shadow: 0 8px 24px rgba(212, 175, 55, 0.1);
    }

    .insight-icon {
      color: #d4af37;
      margin-bottom: 16px;
    }

    .insight-card h3 {
      color: #d4af37;
      margin-bottom: 16px;
      font-size: 1.2rem;
    }

    .insight-card p {
      color: #e0e0e0;
      line-height: 1.6;
    }

    .data-source-info {
      text-align: center;
      padding: 24px;
      background: rgba(212, 175, 55, 0.05);
      border-radius: 12px;
      border: 1px solid rgba(212, 175, 55, 0.1);
    }

    .data-source-info p {
      margin: 8px 0;
      color: #a0a0a0;
      font-size: 0.9rem;
    }

    .data-source-info p:first-child {
      color: #d4af37;
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .trend-education-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .trend-card {
        padding: 20px;
      }

      .trend-value {
        font-size: 1.8rem;
      }

      .trend-value.mega {
        font-size: 2.2rem;
      }

      .insight-card {
        padding: 24px 20px;
      }

      .trend-card.mega-highlight {
        transform: none;
      }
    }
  </style>
<style>
  /* Catalog Product Overrides: mobile single column full width and 4:3 images full-cover */
  .product-grid { grid-template-columns: 1fr !important; }

  @media (min-width: 769px) {
    .product-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }

  /* Ensure product image fills card area with 4:3 ratio consistently */
  .product-card .product-image {
    position: relative;
    aspect-ratio: 4 / 3;
    padding: 0 !important;
    min-height: unset !important;
    border-radius: 16px;
    overflow: hidden;
    background: transparent;
    width: 100%;
  }

  .product-card .product-image img,
  .product-card .product-image picture img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block;
  }

  /* Set text/icon color to black for the badges directly under Katalog h2 */
  .section h2 + div,
  .section h2 + div > div { color: #000 !important; }
  .section h2 + div svg { color: #000 !important; fill: #000 !important; }

  /* Mobile header fit-scale */
  @media (max-width: 768px) {
    header { padding: 30px 0 20px !important; }
    header img {
      width: 100% !important;
      max-width: 320px !important;
      height: auto !important;
      transform: none !important;
      object-fit: contain !important;
    }
  }
</style>
<style>
  /* TV Video Embed Styles (match SG) */
  .tv-card { 
    margin: 1.5rem auto 2rem; 
    max-width: 900px; 
    padding: 0 0.5rem; 
  }
  .hero-content .tv-card { width: 100%; }
  .tv-frame { 
    position: relative; 
    width: 100%; 
    border-radius: 1.2rem; 
    background: #0a0a0a; 
    border: 2px solid rgba(192, 192, 192, 0.3); 
    box-shadow: 0 12px 30px rgba(30, 58, 138, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.08); 
    padding: 0.8rem; 
  }
  .tv-screen { 
    position: relative; 
    border-radius: 0.8rem; 
    overflow: hidden; 
    background: #000; 
    aspect-ratio: 16 / 9; 
  }
  .video-embed { 
    width: 100%; 
    height: 100%; 
    border: 0; 
  }
  .tv-frame::before { 
    content: ''; 
    position: absolute; 
    top: -10px; 
    left: 50%; 
    transform: translateX(-50%); 
    width: 120px; 
    height: 6px; 
    border-radius: 3px; 
    background: linear-gradient(135deg, #F8FAFC, #CBD5E1); 
    box-shadow: 0 4px 12px rgba(148, 163, 184, 0.5); 
    opacity: .6; 
  }
  .tv-stand { 
    width: 140px; 
    height: 10px; 
    background: linear-gradient(135deg, #CBD5E1, #94A3B8); 
    border-radius: 6px; 
    margin: 10px auto 0; 
    box-shadow: 0 6px 16px rgba(30, 58, 138, 0.3), inset 0 1px 0 rgba(255,255,255,0.6); 
  }
  @media (max-width: 600px) {
    .tv-card { margin: 1rem auto 1.5rem; }
    .tv-frame { padding: 0.6rem; border-radius: 1rem; }
    .tv-screen { border-radius: 0.7rem; }
    .tv-stand { width: 100px; height: 8px; }
  }
</style>
</head>
<body>
  <div class="container">

    <!-- HEADER -->
    <header>
      <picture>
        
        <img src="https://bisnisemasperak.com/goldgram/logogg.png" alt="Logo Goldgram" style="max-width: 100%; height: auto;">
      </picture>
    </header>

    <!-- HERO SECTION -->
    <section class="hero">
      <div class="hero-content">
        <h1>Goldgram – Investasi Emas untuk Anda yang Ingin Naik Kelas</h1>
        <p>Mulai kepemilikan emas murni dari 1 gram dengan sistem yang aman, transparan, dan bankable.</p>
        
        <!-- TV-styled Video Embed (match Silvergram) -->
        <div class="tv-card" role="group" aria-label="Video promosi Goldgram">
          <div class="tv-frame">
            <div class="tv-screen">
              <iframe class="video-embed"
                      src="https://www.youtube-nocookie.com/embed/F0EdvkztF6c?controls=0"
                      title="Video Goldgram"
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen"
                      sandbox="allow-scripts allow-same-origin allow-presentation"
                      referrerpolicy="strict-origin-when-cross-origin"
                      allowfullscreen></iframe>
            </div>
          </div>
          <div class="tv-stand" aria-hidden="true"></div>
        </div>
        
        <a href="https://wa.me/[whatsapp]]?text=Halo%20kak%20%5B[[nama]]%5D%2C%20Saya%20ingin%20membeli%20Goldgram%20yang%201%20gram.%20Berapa%20harganya%20hari%20ini%3F" class="cta-btn">Hubungi Kami via WhatsApp</a>
      </div>
    </section>

    <!-- MENGAPA HARUS MENABUNG EMAS -->
    <section class="section">
      <h2>Mengapa Harus Menabung Emas?</h2>
      <div class="gold-investment-section">
        <!-- Main Integrated Chart Card -->
        <div class="main-chart-card">
          <!-- Chart Header -->
          <div class="chart-header">
            <h3>Grafik Harga Emas 5 Tahun Terakhir</h3>
            <div class="data-source">
              <span>Sumber Data: <a href="https://id.bullion-rates.com/" target="_blank" rel="noopener">Bullion-Rates.com</a></span>
            </div>
          </div>
          
          <!-- Chart Container -->
          <div class="chart-wrapper">
            <a href="https://id.bullion-rates.com/gold/IDR/Year-5-chart.htm" id="brtChart_CY0001VHP" target="_blank"></a><br />
            <script type="text/javascript" src="https://www.bullion-rates.com/ScriptWidget.js?sid=CY0001VHP&stk=09I2W6I6N0" charset="utf-8"></script>
          </div>
          
          <!-- Integrated Analysis Grid -->
          <div class="integrated-analysis">
            <div class="analysis-row">
              <div class="analysis-item">
                <div class="analysis-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 3v18h18"/>
                    <path d="M7 12l4-4 4 4 4-4"/>
                  </svg>
                </div>
                <div class="analysis-content">
